/-!
# Playground: interval graphs are perfect

**The result.** The *interval graph* `G` generated by a finite collection `ūĚďė` of intervals of `‚ĄĚ`
is *perfect*: on every induced subgraph `H` the chromatic number equals the clique number,
`Ōá(H) = ŌČ(H)`. The headline theorem is `isPerfect_intervalGraph`.

**Method.** We take the high-level route: intervals graph is hereditary (i.e. an induced subgraph
of an interval graph is also an interval graph), so it suffices to prove `Ōá(G) = ŌČ(G)` for an
arbitrary interval graph. Then we order the intervals by "entirely before", so that
adjacency in `G` implies *incomparability*; then `Ōá(G) = ŌČ(G)` follows from `Ōá(G) ‚Č• ŌČ(G)`
(general inequality) and `Ōá(G) ‚Č§ ŌČ(G)` follows from the application Dilworth's theorem.
Dilworth is imported from `GraphLib/Playground/Dilworth_Mirsky.lean`.

A corollary of this result is the statement "a finite family of intervals splits into `ŌČ`
pairwise-disjoint subfamilies" is just the `ŌČ`-colouring repackaged ‚ÄĒ a special case of the
general colouring corollary in ¬ßD (`ncard_le_chromaticNum_mul_independenceNum`).

**For colleagues.** Declarations carrying a `-- #general` comment are not specific to interval
graphs: they are notions/facts about arbitrary (finite) simple graphs that should live in the core
graph library, not in this playground. A few tagged `#general (specialised)` are currently stated
only for `intervalGraph` but hold for every finite simple graph. We deliberately do not
generalise them here ‚ÄĒ `grep '#general'` lists them all. --> It could be great to formalise
those statements.
-/

namespace GraphLib.Playground
open GraphLib

-- ### The interval graph `G = ‚ü®ūĚďė, E, ‚äā‚ü©`

/-- The interval graph of a finite collection `ūĚďė` of intervals: vertices are the intervals,
and two *distinct* intervals are adjacent iff they intersect. -/
def intervalGraph (ūĚďė : Finset (Set ‚ĄĚ)) : SimpleGraph (Set ‚ĄĚ) where
  vertexSet := ‚ÜĎūĚďė
  edgeSet := {e | ‚ąÉ A ‚ąą ūĚďė, ‚ąÉ B ‚ąą ūĚďė, A ‚Č† B ‚ąß (A ‚ą© B).Nonempty ‚ąß e = s(A, B)}
  incidence' := by
    rintro e ‚ü®A, hA, B, hB, _, _, rfl‚ü© v hv
    rw [Sym2.mem_iff] at hv
    rcases hv with rfl | rfl
    ¬∑ exact Finset.mem_coe.mpr hA
    ¬∑ exact Finset.mem_coe.mpr hB
  loopless' := by
    rintro e ‚ü®A, _, B, _, hne, _, rfl‚ü©
    rw [Sym2.mk_isDiag_iff]
    exact hne

namespace SimpleGraph
variable {őĪ : Type*}

-- ### Clique and clique number `ŌČ`

-- #general
/-- `C` is a clique of `G`: a set of vertices that are pairwise adjacent. -/
def IsClique (G : SimpleGraph őĪ) (C : Set őĪ) : Prop :=
  C ‚äÜ V(G) ‚ąß ‚ąÄ ‚¶Éa‚¶Ą, a ‚ąą C ‚Üí ‚ąÄ ‚¶Éb‚¶Ą, b ‚ąą C ‚Üí a ‚Č† b ‚Üí s(a, b) ‚ąą E(G)

-- #general
/-- The clique number `ŌČ(G)`: the supremum of cardinalities of finite cliques. -/
noncomputable def cliqueNum (G : SimpleGraph őĪ) : ‚Ąē :=
  sSup {n | ‚ąÉ C : Finset őĪ, IsClique G ‚ÜĎC ‚ąß C.card = n}

-- ### Proper coloring and chromatic number `Ōá`

-- #general
/-- `f` is a proper coloring of `G`: adjacent vertices receive distinct colors. -/
def IsProperColoring {őļ : Type*} (G : SimpleGraph őĪ) (f : ‚Ü•(V(G)) ‚Üí őļ) : Prop :=
  ‚ąÄ a b : ‚Ü•(V(G)), s(‚ÜĎa, ‚ÜĎb) ‚ąą E(G) ‚Üí f a ‚Č† f b

-- #general
/-- The chromatic number `Ōá(G)`: the least `n` admitting a proper colouring of the vertices into
`Fin n`. -/
noncomputable def chromaticNum (G : SimpleGraph őĪ) : ‚Ąē :=
  sInf {n | ‚ąÉ f : ‚Ü•(V(G)) ‚Üí Fin n, IsProperColoring G f}

-- ### Perfection

-- #general (also: should be `@[ext]` on the upstream `SimpleGraph` structure)
/-- Two graphs on `őĪ` are equal once their vertex and edge sets agree (the structural axioms are
propositions, hence proof-irrelevant). -/
lemma ext' {G H : SimpleGraph őĪ} (hv : G.vertexSet = H.vertexSet) (he : G.edgeSet = H.edgeSet) :
    G = H := by
  obtain ‚ü®v‚āĀ, e‚āĀ, _, _‚ü© := G
  obtain ‚ü®v‚āā, e‚āā, _, _‚ü© := H
  obtain rfl : v‚āĀ = v‚āā := hv
  obtain rfl : e‚āĀ = e‚āā := he
  rfl

-- #general
/-- The subgraph of `G` induced on a vertex subset `W`: keep `W` as vertices and exactly the edges
of `G` both of whose endpoints lie in `W`. -/
def induce (G : SimpleGraph őĪ) (W : Set őĪ) : SimpleGraph őĪ where
  vertexSet := W
  edgeSet := {e ‚ąą G.edgeSet | ‚ąÄ v ‚ąą e, v ‚ąą W}
  incidence' := fun _ he _ hv => he.2 _ hv
  loopless' := fun _ he => G.loopless' _ he.1

-- #general
/-- A simple graph is *perfect* when every induced subgraph has equal chromatic and clique
numbers. -/
def IsPerfect (G : SimpleGraph őĪ) : Prop :=
  ‚ąÄ ‚¶ÉW‚¶Ą, W ‚äÜ V(G) ‚Üí chromaticNum (induce G W) = cliqueNum (induce G W)

end SimpleGraph

-- ## A. Analytic helpers and graph lemmas

open SimpleGraph Set

/-! ### Unfolding the interval graph's vertex and edge sets -/

@[simp] lemma vertexSet_intervalGraph (ūĚďė : Finset (Set ‚ĄĚ)) :
    V(intervalGraph ūĚďė) = (‚ÜĎūĚďė : Set (Set ‚ĄĚ)) := rfl

@[simp] lemma edgeSet_intervalGraph (ūĚďė : Finset (Set ‚ĄĚ)) :
    E(intervalGraph ūĚďė) =
      {e | ‚ąÉ A ‚ąą ūĚďė, ‚ąÉ B ‚ąą ūĚďė, A ‚Č† B ‚ąß (A ‚ą© B).Nonempty ‚ąß e = s(A, B)} := rfl

/-- adjacency in the interval graph: `s(A,B)` is an edge iff `A, B` are distinct members of
`ūĚďė` that intersect. This is the direct Lean reading of the set-theoretic edge relation. -/
lemma mem_edgeSet_intervalGraph {ūĚďė : Finset (Set ‚ĄĚ)} {A B : Set ‚ĄĚ} :
    s(A, B) ‚ąą E(intervalGraph ūĚďė) ‚ÜĒ A ‚ąą ūĚďė ‚ąß B ‚ąą ūĚďė ‚ąß A ‚Č† B ‚ąß (A ‚ą© B).Nonempty := by
  rw [edgeSet_intervalGraph, Set.mem_setOf_eq]
  constructor
  ¬∑ rintro ‚ü®A', hA', B', hB', hne', hAB', he‚ü©
    rw [Sym2.eq_iff] at he
    rcases he with ‚ü®rfl, rfl‚ü© | ‚ü®rfl, rfl‚ü©
    ¬∑ exact ‚ü®hA', hB', hne', hAB'‚ü©
    ¬∑ refine ‚ü®hB', hA', hne'.symm, ?_‚ü©
      rwa [Set.inter_comm]
  ¬∑ rintro ‚ü®hA, hB, hne, hAB‚ü©
    exact ‚ü®A, hA, B, hB, hne, hAB, rfl‚ü©

/-! ### Clique bookkeeping -/

-- #general (specialised) ‚ÄĒ `IsClique G ‚ąÖ` for any graph `G`
/-- The empty set is a clique of the interval graph. -/
lemma isClique_empty (ūĚďė : Finset (Set ‚ĄĚ)) :
    IsClique (intervalGraph ūĚďė) (‚ÜĎ(‚ąÖ : Finset (Set ‚ĄĚ))) := by
  rw [Finset.coe_empty]; exact ‚ü®Set.empty_subset _, fun a ha => absurd ha (Set.notMem_empty a)‚ü©

-- #general (specialised) ‚ÄĒ clique cardinalities are bounded above for any finite-vertex graph
/-- The set of clique cardinalities is bounded above: every clique is a subfamily of `ūĚďė`, so has at
most `ūĚďė.card` members. (Needed so that the `sSup` defining `cliqueNum` behaves as a maximum.) -/
lemma cliqueNum_bddAbove (ūĚďė : Finset (Set ‚ĄĚ)) :
    BddAbove {n | ‚ąÉ C : Finset (Set ‚ĄĚ), IsClique (intervalGraph ūĚďė) ‚ÜĎC ‚ąß C.card = n} := by
  refine ‚ü®ūĚďė.card, ?_‚ü©
  rintro n ‚ü®C, ‚ü®hsub, _‚ü©, rfl‚ü©
  refine Finset.card_le_card fun a ha => ?_
  have : a ‚ąą V(intervalGraph ūĚďė) := hsub (Finset.mem_coe.mpr ha)
  rwa [vertexSet_intervalGraph, Finset.mem_coe] at this

-- #general (specialised) ‚ÄĒ holds for any finite-vertex graph
/-- The cardinality of a clique is bounded above by the clique number. -/
lemma card_le_cliqueNum {ūĚďė : Finset (Set ‚ĄĚ)} {Q : Finset (Set ‚ĄĚ)}
    (h : IsClique (intervalGraph ūĚďė) ‚ÜĎQ) : Q.card ‚Č§ cliqueNum (intervalGraph ūĚďė) := by
  apply le_csSup (cliqueNum_bddAbove ūĚďė); exact ‚ü®Q, h, rfl‚ü©

/-! ## B. `Ōá(G) ‚Č§ ŌČ(G)` via Dilworth's theorem

Order the intervals by "entirely before" (`intervalLE`): two *distinct* intervals are comparable
iff disjoint, so adjacency in `intervalGraph` is exactly incomparability. Dilworth's theorem (via
`dilworth_rel`) yields an antichain `A` and a chain cover `ūĚíě` of equal size: the antichain is a
clique (`|A| ‚Č§ ŌČ`) and the chain cover is a proper colouring (`Ōá ‚Č§ |ūĚíě|`), so `Ōá ‚Č§ |ūĚíě| = |A| ‚Č§ ŌČ`. -/

/-- The interval order: `A ‚Čľ B` iff `A = B`, or `B` is non-empty and every point of `A` is below
every point of `B` ("`A` entirely before `B`"). The `B.Nonempty` guard makes `‚ąÖ` a global minimum,
so this is a genuine partial order on *all* of `Set ‚ĄĚ` (empty intervals included). -/
def intervalLE (A B : Set ‚ĄĚ) : Prop := A = B ‚ą® (B.Nonempty ‚ąß ‚ąÄ x ‚ąą A, ‚ąÄ y ‚ąą B, x < y)

lemma intervalLE_refl (A : Set ‚ĄĚ) : intervalLE A A := Or.inl rfl

lemma intervalLE_trans {A B C : Set ‚ĄĚ} (hAB : intervalLE A B) (hBC : intervalLE B C) :
    intervalLE A C := by
  rcases hAB with rfl | ‚ü®hBne, hAB‚ü©
  ¬∑ exact hBC
  ¬∑ rcases hBC with rfl | ‚ü®hCne, hBC‚ü©
    ¬∑ exact Or.inr ‚ü®hBne, hAB‚ü©
    ¬∑ obtain ‚ü®z, hz‚ü© := hBne
      exact Or.inr ‚ü®hCne, fun x hx y hy => lt_trans (hAB x hx z hz) (hBC z hz y hy)‚ü©

lemma intervalLE_antisymm {A B : Set ‚ĄĚ} (hAB : intervalLE A B) (hBA : intervalLE B A) : A = B := by
  rcases hAB with rfl | ‚ü®hBne, hAB‚ü©
  ¬∑ rfl
  ¬∑ rcases hBA with rfl | ‚ü®hAne, hBA‚ü©
    ¬∑ rfl
    ¬∑ obtain ‚ü®x, hx‚ü© := hAne; obtain ‚ü®y, hy‚ü© := hBne
      exact absurd (lt_trans (hAB x hx y hy) (hBA y hy x hx)) (lt_irrefl x)

/-- `‚ąÖ` is the least interval. -/
lemma intervalLE_empty (B : Set ‚ĄĚ) : intervalLE ‚ąÖ B :=
  B.eq_empty_or_nonempty.elim (fun h => Or.inl h.symm)
    fun h => Or.inr ‚ü®h, fun x hx => absurd hx (Set.notMem_empty x)‚ü©

/-- Comparable intervals are equal or disjoint (so within a chain, distinct intervals are
disjoint). -/
lemma eq_or_disjoint_of_intervalLE {A B : Set ‚ĄĚ} (h : intervalLE A B) :
    A = B ‚ą® ¬¨ (A ‚ą© B).Nonempty :=
  h.imp_right fun ‚ü®_, hAB‚ü© ‚ü®z, hzA, hzB‚ü© => absurd (hAB z hzA z hzB) (lt_irrefl z)

/-- **The geometric heart.** Two non-empty intervals, neither entirely before the other, overlap. -/
lemma inter_nonempty_of_not_intervalLE {A B : Set ‚ĄĚ} (hA : A.OrdConnected) (hB : B.OrdConnected)
    (hAB : ¬¨ ‚ąÄ x ‚ąą A, ‚ąÄ y ‚ąą B, x < y) (hBA : ¬¨ ‚ąÄ x ‚ąą B, ‚ąÄ y ‚ąą A, x < y) :
    (A ‚ą© B).Nonempty := by
  push Not at hAB hBA
  obtain ‚ü®a, ha, b, hb, hba‚ü© := hAB
  obtain ‚ü®b', hb', a', ha', ha'b'‚ü© := hBA
  rcases le_total a' b with h | h
  ¬∑ exact ‚ü®b, hA.out ha' ha ‚ü®h, hba‚ü©, hb‚ü©
  ¬∑ exact ‚ü®a', ha', hB.out hb hb' ‚ü®h, ha'b'‚ü©‚ü©

/-- Distinct *incomparable* intervals overlap (within an antichain, distinct intervals meet); `‚ąÖ` is
the global minimum, hence comparable to everything. -/
lemma inter_nonempty_of_incomp {A B : Set ‚ĄĚ} (hA : A.OrdConnected) (hB : B.OrdConnected)
    (hnAB : ¬¨ intervalLE A B) (hnBA : ¬¨ intervalLE B A) : (A ‚ą© B).Nonempty := by
  have hAne : A.Nonempty := by
    rcases A.eq_empty_or_nonempty with rfl | h
    exacts [absurd (intervalLE_empty B) hnAB, h]
  have hBne : B.Nonempty := by
    rcases B.eq_empty_or_nonempty with rfl | h
    exacts [absurd (intervalLE_empty A) hnBA, h]
  exact inter_nonempty_of_not_intervalLE hA hB
    (fun h => hnAB (Or.inr ‚ü®hBne, h‚ü©)) (fun h => hnBA (Or.inr ‚ü®hAne, h‚ü©))

/-- **Dilworth's theorem, relation form.** `dilworth` for an explicit partial-order relation `r`,
installed as a `PartialOrder` on the *abstract* `őĪ` ‚ÄĒ which has no ambient `‚Č§`/`<`, so the default
`lt` synthesizes and there is no instance clash (unlike installing it directly on `Set ‚ĄĚ`, whose
`<` is `‚äā`). The local instance makes `(¬∑ ‚Č§ ¬∑)` definitionally `r`, so `dilworth` proves the goal
outright; the conclusion is re-exposed via `r` (Mathlib's `IsAntichain`/`IsChain` at `r`). -/
theorem dilworth_rel {őĪ : Type*} [DecidableEq őĪ] (s : Finset őĪ) (r : őĪ ‚Üí őĪ ‚Üí Prop)
    (hrefl : ‚ąÄ a, r a a) (htrans : ‚ąÄ a b c, r a b ‚Üí r b c ‚Üí r a c)
    (hantisymm : ‚ąÄ a b, r a b ‚Üí r b a ‚Üí a = b) :
    ‚ąÉ (A : Finset őĪ) (ūĚíě : Finset (Finset őĪ)),
      A ‚äÜ s ‚ąß IsAntichain r ‚ÜĎA ‚ąß
      s = ūĚíě.biUnion id ‚ąß (‚ąÄ C ‚ąą ūĚíě, IsChain r ‚ÜĎC) ‚ąß ūĚíě.card = A.card := by
  letI : PartialOrder őĪ :=
    { le := r, le_refl := hrefl, le_trans := htrans, le_antisymm := hantisymm }
  exact dilworth s

/-- **Dilworth applied to the interval order.** A proper colouring of the vertices into `Fin d`
together with `d ‚Č§ ŌČ(G)` ‚ÄĒ the whole content of `Ōá(G) ‚Č§ ŌČ(G)`. The chain cover gives the colouring
(same colour ‚üĻ same chain ‚üĻ comparable ‚üĻ disjoint); the antichain is a clique. -/
lemma exists_proper_coloring_le_cliqueNum (ūĚďė : Finset (Set ‚ĄĚ))
    (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    ‚ąÉ (d : ‚Ąē) (f : ‚Ü•(V(intervalGraph ūĚďė)) ‚Üí Fin d),
      IsProperColoring (intervalGraph ūĚďė) f ‚ąß d ‚Č§ cliqueNum (intervalGraph ūĚďė) := by
  classical
  obtain ‚ü®A, ūĚíě, hAsub, hAanti, hcov, hchains, hcard‚ü© :=
    dilworth_rel ūĚďė intervalLE intervalLE_refl (fun _ _ _ => intervalLE_trans)
      (fun _ _ => intervalLE_antisymm)
  -- every vertex lies in some chain of the cover; choose one and colour by its index
  have hmem : ‚ąÄ a : ‚Ü•(V(intervalGraph ūĚďė)), ‚ąÉ C ‚ąą ūĚíě, a.1 ‚ąą C := by
    rintro ‚ü®x, hx‚ü©
    rw [vertexSet_intervalGraph, Finset.mem_coe, hcov] at hx
    simpa using hx
  choose C hC haC using hmem
  refine ‚ü®ūĚíě.card, fun a => ūĚíě.equivFin ‚ü®C a, hC a‚ü©, fun a b hab heq => ?_, ?_‚ü©
  ¬∑ obtain ‚ü®_, _, hne, hmeet‚ü© := mem_edgeSet_intervalGraph.mp hab
    have hCab : C a = C b := congrArg Subtype.val (ūĚíě.equivFin.injective heq)
    have hbCa : b.1 ‚ąą C a := by rw [hCab]; exact haC b
    rcases hchains (C a) (hC a) (haC a) hbCa hne with h | h <;>
      rcases eq_or_disjoint_of_intervalLE h with he | hd
    ¬∑ exact hne he
    ¬∑ exact hd hmeet
    ¬∑ exact hne he.symm
    ¬∑ exact hd (by rwa [Set.inter_comm])
  ¬∑ rw [hcard]
    refine card_le_cliqueNum ‚ü®fun B hB => hAsub hB, fun B hB D hD hBD => ?_‚ü©
    rw [mem_edgeSet_intervalGraph]
    exact ‚ü®hAsub hB, hAsub hD, hBD, inter_nonempty_of_incomp (hI B (hAsub hB)) (hI D (hAsub hD))
      (hAanti hB hD hBD) (hAanti hD hB hBD.symm)‚ü©

/-! ## C. The headline results: `Ōá = ŌČ` and perfection

`Ōá ‚Č§ ŌČ` is ¬ßB; `ŌČ ‚Č§ Ōá` holds for every finite graph (a clique injects into the colours). Hence
`Ōá = ŌČ` (`chromaticNum_eq_cliqueNum_intervalGraph`), and by heredity (an induced subgraph of an
interval graph is an interval graph, `induce_intervalGraph`) this lifts to perfection
(`isPerfect_intervalGraph`). -/

/-- A proper colouring of the vertices into `Fin (Ōá G)` exists (the `Ōá`-set is non-empty by ¬ßB, so
its `sInf` is attained). -/
lemma exists_coloring_chromaticNum (ūĚďė : Finset (Set ‚ĄĚ)) (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    ‚ąÉ f : ‚Ü•(V(intervalGraph ūĚďė)) ‚Üí Fin (chromaticNum (intervalGraph ūĚďė)),
      IsProperColoring (intervalGraph ūĚďė) f := by
  obtain ‚ü®d, f, hf, _‚ü© := exists_proper_coloring_le_cliqueNum ūĚďė hI
  have hmem : d ‚ąą {n | ‚ąÉ f : ‚Ü•(V(intervalGraph ūĚďė)) ‚Üí Fin n, IsProperColoring (intervalGraph ūĚďė) f} :=
    ‚ü®f, hf‚ü©
  exact Nat.sInf_mem ‚ü®d, hmem‚ü©

/-- **Key inequality.** For an interval graph, `Ōá(G) ‚Č§ ŌČ(G)` (Dilworth, ¬ßB). -/
theorem chromaticNum_le_cliqueNum_intervalGraph
    (ūĚďė : Finset (Set ‚ĄĚ)) (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    chromaticNum (intervalGraph ūĚďė) ‚Č§ cliqueNum (intervalGraph ūĚďė) := by
  obtain ‚ü®d, f, hf, hd‚ü© := exists_proper_coloring_le_cliqueNum ūĚďė hI
  have hmem : d ‚ąą {n | ‚ąÉ f : ‚Ü•(V(intervalGraph ūĚďė)) ‚Üí Fin n, IsProperColoring (intervalGraph ūĚďė) f} :=
    ‚ü®f, hf‚ü©
  exact le_trans (Nat.sInf_le hmem) hd

-- #general (specialised) ‚ÄĒ `ŌČ(G) ‚Č§ Ōá(G)` for any finite graph (the proof never uses intervals)
/-- The reverse inequality `ŌČ(G) ‚Č§ Ōá(G)`, holding for every (finite) graph: a clique injects into
the colours. -/
theorem cliqueNum_le_chromaticNum_intervalGraph
    (ūĚďė : Finset (Set ‚ĄĚ)) (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    cliqueNum (intervalGraph ūĚďė) ‚Č§ chromaticNum (intervalGraph ūĚďė) := by
  classical
  obtain ‚ü®f, hf‚ü© := exists_coloring_chromaticNum ūĚďė hI
  apply csSup_le
  ¬∑ exact ‚ü®0, ‚ąÖ, isClique_empty ūĚďė, Finset.card_empty‚ü©
  ¬∑ rintro m ‚ü®C, hC, rfl‚ü©
    have key : ‚ąÄ A ‚ąą (‚ÜĎC : Set (Set ‚ĄĚ)), A ‚ąą V(intervalGraph ūĚďė) := fun A hA => hC.1 hA
    calc C.card
        ‚Č§ (Finset.range (chromaticNum (intervalGraph ūĚďė))).card :=
          Finset.card_le_card_of_injOn
            (fun A => if h : A ‚ąą V(intervalGraph ūĚďė) then (f ‚ü®A, h‚ü©).1 else 0)
            (fun A hA => Finset.mem_coe.mpr (Finset.mem_range.mpr (by
              simp only [dif_pos (key A hA)]; exact (f ‚ü®A, key A hA‚ü©).2)))
            (fun A hA B hB hAB => by
              simp only [dif_pos (key A hA), dif_pos (key B hB)] at hAB
              by_contra hne2
              exact hf ‚ü®A, key A hA‚ü© ‚ü®B, key B hB‚ü© (hC.2 hA hB hne2) (Fin.val_injective hAB))
      _ = chromaticNum (intervalGraph ūĚďė) := Finset.card_range _

/-- **Single-graph equality.** `Ōá(G) = ŌČ(G)` for an interval graph. -/
theorem chromaticNum_eq_cliqueNum_intervalGraph
    (ūĚďė : Finset (Set ‚ĄĚ)) (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    chromaticNum (intervalGraph ūĚďė) = cliqueNum (intervalGraph ūĚďė) :=
  le_antisymm (chromaticNum_le_cliqueNum_intervalGraph ūĚďė hI)
    (cliqueNum_le_chromaticNum_intervalGraph ūĚďė hI)

open Classical in
/-- **Heredity.** An induced subgraph of an interval graph is again an interval graph: inducing on
a vertex subset `W ‚äÜ ‚ÜĎūĚďė` gives the interval graph of the subfamily `ūĚďė.filter (¬∑ ‚ąą W)`. -/
lemma induce_intervalGraph {ūĚďė : Finset (Set ‚ĄĚ)} {W : Set (Set ‚ĄĚ)} (hW : W ‚äÜ ‚ÜĎūĚďė) :
    induce (intervalGraph ūĚďė) W = intervalGraph (ūĚďė.filter (¬∑ ‚ąą W)) := by
  apply SimpleGraph.ext'
  ¬∑ change W = ‚ÜĎ(ūĚďė.filter (¬∑ ‚ąą W))
    rw [Finset.coe_filter]
    exact Set.ext fun A => ‚ü®fun h => ‚ü®hW h, h‚ü©, fun h => h.2‚ü©
  ¬∑ change {e ‚ąą (intervalGraph ūĚďė).edgeSet | ‚ąÄ v ‚ąą e, v ‚ąą W}
        = (intervalGraph (ūĚďė.filter (¬∑ ‚ąą W))).edgeSet
    ext e
    induction e using Sym2.ind with
    | _ A B =>
      rw [Set.mem_sep_iff,
        show (intervalGraph ūĚďė).edgeSet = E(intervalGraph ūĚďė) from rfl, mem_edgeSet_intervalGraph,
        show (intervalGraph (ūĚďė.filter (¬∑ ‚ąą W))).edgeSet = E(intervalGraph (ūĚďė.filter (¬∑ ‚ąą W)))
          from rfl, mem_edgeSet_intervalGraph]
      simp only [Finset.mem_filter]
      constructor
      ¬∑ rintro ‚ü®‚ü®hA, hB, hne, hint‚ü©, hvW‚ü©
        exact ‚ü®‚ü®hA, hvW A (Sym2.mem_mk_left A B)‚ü©, ‚ü®hB, hvW B (Sym2.mem_mk_right A B)‚ü©, hne, hint‚ü©
      ¬∑ rintro ‚ü®‚ü®hA, hAW‚ü©, ‚ü®hB, hBW‚ü©, hne, hint‚ü©
        refine ‚ü®‚ü®hA, hB, hne, hint‚ü©, ?_‚ü©
        intro v hv
        rw [Sym2.mem_iff] at hv
        rcases hv with rfl | rfl
        exacts [hAW, hBW]

/-- **The interval graph is perfect.** Every induced subgraph has `Ōá = ŌČ`, by heredity
(`induce_intervalGraph`) reducing each to the single-graph
`chromaticNum_eq_cliqueNum_intervalGraph`. -/
theorem isPerfect_intervalGraph
    (ūĚďė : Finset (Set ‚ĄĚ)) (hI : ‚ąÄ A ‚ąą ūĚďė, Set.OrdConnected A) :
    IsPerfect (intervalGraph ūĚďė) := by
  classical
  intro W hW
  rw [vertexSet_intervalGraph] at hW
  rw [induce_intervalGraph hW]
  exact chromaticNum_eq_cliqueNum_intervalGraph _
    (fun A hA => hI A (Finset.mem_filter.mp hA).1)

/-! ## D. A general corollary: a colouring splits the vertices into independent sets

Not about intervals: for any graph with finite vertex set, an optimal colouring splits `V(G)` into
`Ōá(G)` independent classes, each of size `‚Č§ őĪ(G)`, giving `|V(G)| ‚Č§ Ōá(G) ¬∑ őĪ(G)`. The classical
"partition into pairwise-disjoint subfamilies" is the special case `G = intervalGraph ūĚďė`. -/

namespace SimpleGraph
variable {őĪ : Type*}

-- #general
/-- `S` is an *independent set* of `G`: a set of pairwise non-adjacent vertices. -/
def IsIndependentSet (G : SimpleGraph őĪ) (S : Set őĪ) : Prop :=
  S ‚äÜ V(G) ‚ąß ‚ąÄ ‚¶Éa‚¶Ą, a ‚ąą S ‚Üí ‚ąÄ ‚¶Éb‚¶Ą, b ‚ąą S ‚Üí a ‚Č† b ‚Üí s(a, b) ‚ąČ E(G)

-- #general
/-- The independence number `őĪ(G)`: the supremum of cardinalities of finite independent sets. -/
noncomputable def independenceNum (G : SimpleGraph őĪ) : ‚Ąē :=
  sSup {n | ‚ąÉ S : Finset őĪ, IsIndependentSet G ‚ÜĎS ‚ąß S.card = n}

end SimpleGraph

open SimpleGraph

-- #general
/-- When `V(G)` is finite, the independent-set cardinalities are bounded above by `|V(G)|`. -/
lemma independenceNum_bddAbove {őĪ : Type*} (G : SimpleGraph őĪ) (hV : (V(G)).Finite) :
    BddAbove {n | ‚ąÉ S : Finset őĪ, IsIndependentSet G ‚ÜĎS ‚ąß S.card = n} := by
  refine ‚ü®hV.toFinset.card, ?_‚ü©
  rintro n ‚ü®S, ‚ü®hSsub, _‚ü©, rfl‚ü©
  exact Finset.card_le_card fun a ha => hV.mem_toFinset.mpr (hSsub (Finset.mem_coe.mpr ha))

-- #general
/-- **Colouring bound.** For any graph with finite vertex set, `|V(G)| ‚Č§ Ōá(G) ¬∑ őĪ(G)`: an optimal
proper colouring splits `V(G)` into `Ōá(G)` colour classes, each an independent set of size `‚Č§ őĪ(G)`.
The classical interval partition is the special case `G = intervalGraph ūĚďė`, `Ōá = ŌČ`. -/
theorem ncard_le_chromaticNum_mul_independenceNum {őĪ : Type*} (G : SimpleGraph őĪ)
    (hV : (V(G)).Finite) : (V(G)).ncard ‚Č§ chromaticNum G * independenceNum G := by
  classical
  haveI : Fintype ‚Ü•(V(G)) := hV.fintype
  -- an optimal proper colouring `f : V(G) ‚Üí Fin (Ōá G)` exists (the `Ōá`-set is nonempty)
  obtain ‚ü®f, hf‚ü© : ‚ąÉ f : ‚Ü•(V(G)) ‚Üí Fin (chromaticNum G), IsProperColoring G f := by
    have hmem : Fintype.card ‚Ü•(V(G)) ‚ąą
        {n | ‚ąÉ f : ‚Ü•(V(G)) ‚Üí Fin n, IsProperColoring G f} := by
      refine ‚ü®Fintype.equivFin ‚Ü•(V(G)), fun a b hab heq => ?_‚ü©
      have hab' : a = b := (Fintype.equivFin _).injective heq
      subst hab'
      exact G.loopless hab (Sym2.mk_isDiag_iff.mpr rfl)
    exact Nat.sInf_mem ‚ü®_, hmem‚ü©
  -- spread `f` to a total colour `g : őĪ ‚Üí ‚Ąē`
  set g : őĪ ‚Üí ‚Ąē := fun a => if h : a ‚ąą V(G) then (f ‚ü®a, h‚ü©).1 else 0 with hg
  have hgV : ‚ąÄ a (h : a ‚ąą V(G)), g a = (f ‚ü®a, h‚ü©).1 := fun a h => by simp only [hg, dif_pos h]
  -- every vertex gets a colour `< Ōá G`
  have hcover : ‚ąÄ a ‚ąą hV.toFinset, g a ‚ąą Finset.range (chromaticNum G) := by
    intro a ha
    have haV := hV.mem_toFinset.mp ha
    rw [Finset.mem_range, hgV a haV]
    exact (f ‚ü®a, haV‚ü©).2
  -- each colour class is an independent set, so has `‚Č§ őĪ(G)` elements
  have hclass : ‚ąÄ i, (hV.toFinset.filter (fun a => g a = i)).card ‚Č§ independenceNum G := by
    intro i
    apply le_csSup (independenceNum_bddAbove G hV)
    refine ‚ü®hV.toFinset.filter (fun a => g a = i),
      ‚ü®fun a ha => ?_, fun a ha b hb hab hedge => ?_‚ü©, rfl‚ü©
    ¬∑ rw [Finset.mem_coe, Finset.mem_filter] at ha
      exact hV.mem_toFinset.mp ha.1
    ¬∑ rw [Finset.mem_coe, Finset.mem_filter] at ha hb
      have haV := hV.mem_toFinset.mp ha.1
      have hbV := hV.mem_toFinset.mp hb.1
      have hval : (f ‚ü®a, haV‚ü©).1 = (f ‚ü®b, hbV‚ü©).1 := by
        rw [‚Üź hgV a haV, ‚Üź hgV b hbV, ha.2, hb.2]
      exact hf ‚ü®a, haV‚ü© ‚ü®b, hbV‚ü© hedge (Fin.val_injective hval)
  -- sum the colour fibres
  rw [Set.ncard_eq_toFinset_card _ hV, Finset.card_eq_sum_card_fiberwise hcover]
  calc ‚ąĎ i ‚ąą Finset.range (chromaticNum G), (hV.toFinset.filter (fun a => g a = i)).card
      ‚Č§ ‚ąĎ _i ‚ąą Finset.range (chromaticNum G), independenceNum G :=
        Finset.sum_le_sum fun i _ => hclass i
    _ = chromaticNum G * independenceNum G := by
        rw [Finset.sum_const, Finset.card_range, smul_eq_mul]

end GraphLib.Playground
